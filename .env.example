# ClipCut Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Monitoring & Analytics
# Endpoint that receives analytics events (POST JSON)
VITE_ANALYTICS_ENDPOINT=
# Optional Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
# Minimum log level (debug, info, warn, error)
VITE_LOG_LEVEL=info
# Optional Sentry DSN (if Sentry is loaded in host page)
VITE_SENTRY_DSN=
# Enable extra Sentry debugging logs in development (true/false)
VITE_SENTRY_DEBUG=false
# Optional webhook for critical error notifications
VITE_ERROR_ALERT_WEBHOOK_URL=
# Number of critical errors in 5 minutes before alerting
VITE_ERROR_ALERT_THRESHOLD=3

# AI Features (Cloudflare Workers AI — free, 10,000 requests/day)
# 1. Go to https://dash.cloudflare.com → AI → Workers AI
# 2. Create an API token: My Profile → API Tokens → Create Token → "Cloudflare Workers AI" template
# 3. Get your Account ID from the right sidebar on any Cloudflare dashboard page


# Optional: Additional configuration
# VITE_APP_ENV=development
# VITE_APP_VERSION=0.1.0
