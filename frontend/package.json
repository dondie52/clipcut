{
  "name": "clipcut",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "analyze": "ANALYZE=true vite build",
    "build:stats": "vite build && npm run analyze",
    "optimize:images": "node scripts/optimize-images.mjs",
    "check:performance": "node scripts/check-performance-budget.mjs",
    "build:check": "npm run build && npm run check:performance",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "predeploy": "vite build --base /clipcut/ && cp dist/index.html dist/404.html",
    "deploy": "gh-pages -d dist"
  },
  "homepage": "https://dondie52.github.io/clipcut/",
  "dependencies": {
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mediapipe/tasks-vision": "^0.10.32",
    "@sentry/react": "^10.40.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs": "^4.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-ga4": "^2.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "sharp": "^0.34.5",
    "supabase": "^2.76.16",
    "vite": "^5.0.8",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
